# Copy this file to .env and fill in your credentials
# DO NOT commit .env to git!

# Planet Labs API Key (optional - for high-res commercial imagery)
PL_API_KEY=your_planet_api_key_here

# Copernicus Data Space Ecosystem credentials (optional - for CDSE access)
CDSE_CLIENT_ID=your_cdse_client_id_here
CDSE_CLIENT_SECRET=your_cdse_client_secret_here
