{
  "name": "sentinel-hub-timelapse",
  "version": "1.0.0",
  "description": "Automated time-lapse generation from Sentinel-2 L2A satellite imagery",
  "author": "Sentinel Hub API User",
  "license": "MIT",
  "python_requirements": {
    "python": ">=3.8",
    "packages": [
      "requests>=2.28.0",
      "rasterio>=1.3.0",
      "opencv-python>=4.7.0",
      "numpy>=1.21.0"
    ]
  },
  "project_structure": {
    "config.py": "Configuration (credentials, AOI, date range)",
    "collect_imagery.py": "Download Sentinel-2 L2A GeoTIFFs from CDSE",
    "create_timelapse.py": "Generate MP4 time-lapse from GeoTIFFs",
    "setup.sh": "Quick setup script",
    "README.md": "Full documentation",
    "archive/": "Downloaded GeoTIFF files (organized by AOI)",
    "timelapse_output/": "Output MP4 videos"
  },
  "workflow": [
    "1. Get OAuth2 credentials from https://dataspace.copernicus.eu",
    "2. Edit config.py with CDSE_CLIENT_ID and CDSE_CLIENT_SECRET",
    "3. Run: python3 collect_imagery.py [tehran|isfahan]",
    "4. Run: python3 create_timelapse.py --aoi [tehran|isfahan]",
    "5. Output: timelapse_output/timelapse.mp4"
  ]
}
